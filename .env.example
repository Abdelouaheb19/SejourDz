# GEMINI_API_KEY: Optional. Used only for AI travel itinerary customizer suggestions.
# If not specified, the app automatically runs in standard mode without raising any errors.
# GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ================= EMAIL SMTP CONFIGURATION =================
# Host SMTP du serveur de messagerie (ex: smtp.gmail.com pour Gmail)
SMTP_HOST="smtp.gmail.com"

# Port SMTP du serveur (465 pour SSL ou 587 pour TLS)
SMTP_PORT=465

# Définir à "true" si vous utilisez le port 465 (SSL)
SMTP_SECURE="true"

# Votre adresse e-mail d'envoi (ex: votre_adresse@gmail.com)
SMTP_USER="bouhelalabdelouaheb86@gmail.com"

# Votre mot de passe de messagerie ou un mot de passe d'application Google (RECOMMANDÉ)
# Pour Gmail : N'utilisez pas votre mot de passe habituel. Générez un "Mot de passe d'application"
# dans les paramètres de sécurité de votre compte Google : https://myaccount.google.com/apppasswords
SMTP_PASS="mqnnotxvafkgkqgw"

# Adresse e-mail de l'expéditeur affichée pour les clients (facultatif)
SMTP_FROM="\"Séjours DZ - Évasion Voyages\" <votre_adresse@gmail.com>"